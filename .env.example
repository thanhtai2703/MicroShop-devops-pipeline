# Shared runtime defaults
NODE_ENV=development
PORT=8000

# auth-service and api-gateway
JWT_SECRET=local-development-secret-change-me
JWT_EXPIRES_IN=1h

# auth-service, product-service, or order-service.
# Replace SERVICE_DB with auth_db, product_db, or order_db for that service.
DATABASE_URL=postgresql://microshop:microshop@localhost:5432/SERVICE_DB

# product-service and cart-service
REDIS_URL=redis://localhost:6379/0

# Internal service discovery
AUTH_SERVICE_URL=http://auth-service:8000
PRODUCT_SERVICE_URL=http://product-service:8000
CART_SERVICE_URL=http://cart-service:8000
ORDER_SERVICE_URL=http://order-service:8000
PAYMENT_SERVICE_URL=http://payment-service:8000

# api-gateway and service-to-service HTTP calls
UPSTREAM_TIMEOUT_MS=5000

# payment-service; useful for exercising checkout failure handling
PAYMENT_FORCE_DECLINE=false

# frontend; keep API calls relative so the Vite/Nginx proxy owns routing
VITE_API_BASE_URL=/api
GATEWAY_URL=http://localhost:8000
